---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

import { getFriendlyDate } from "@lib/utils";

const { post, index } = Astro.props;

const publishedAtDateFriendly = getFriendlyDate(post.frontmatter.publishedAt);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/blogs/**/*.{png,jpg,jpeg,gif,svg}",
);
const imagePath = Object.keys(images).find((image) =>
  image.includes(post.frontmatter.image.url),
);
const image = images[imagePath!];
---

<a
  href={post.url}
  class="group block border-t border-rule py-10 transition-colors hover:bg-vellum/[0.015]"
>
  <article class="grid grid-cols-1 items-start gap-8 md:grid-cols-12">
    <p
      class="md:col-span-1 font-display text-4xl leading-none tracking-masthead text-ember md:text-5xl"
      style="font-variation-settings:'opsz' 144,'SOFT' 20,'wght' 380;"
    >
      {index}
    </p>

    <div class="md:col-span-7">
      <div class="flex items-center gap-3 font-mono text-[0.68rem] uppercase tracking-widest text-ash">
        <span>{publishedAtDateFriendly}</span>
        <span class="text-bone">·</span>
        <span>{post.frontmatter.minutesRead}</span>
      </div>
      <h2
        class="mt-3 font-display text-3xl leading-[1.06] tracking-masthead text-vellum md:text-4xl"
        style="font-variation-settings:'opsz' 144,'SOFT' 25,'wght' 440;"
      >
        {post.frontmatter.title}
      </h2>
      <p class="mt-4 max-w-[55ch] text-base leading-relaxed text-bone">
        {post.frontmatter.excerpt}
      </p>
      <span class="mt-5 inline-flex items-center gap-2 font-mono text-[0.7rem] uppercase tracking-widest text-vellum">
        Read the piece
        <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
      </span>
    </div>

    <div class="md:col-span-4 overflow-hidden border border-rule">
      <Image
        class="w-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.03]"
        style="filter: saturate(0.82) contrast(1.02);"
        src={image()}
        alt={post.frontmatter.image.alt}
      />
    </div>
  </article>
</a>
