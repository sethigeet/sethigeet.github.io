---
import { Image } from "astro:assets";

interface Props {
  college: string;
  startDate: string;
  endDate: string;
  logo: ImageMetadata;
  isCurrent?: boolean;
}
const { college, startDate, endDate, logo, isCurrent = false } = Astro.props;
---

<article class="relative grid grid-cols-1 gap-6 border-l border-rule pl-6 md:grid-cols-[auto,1fr] md:gap-10">
  {
    isCurrent && (
      <span class="absolute -left-[5px] top-2 inline-block h-2 w-2 rounded-full bg-ember animate-flicker" />
    )
  }

  <div class="flex items-center gap-4">
    <Image
      class="h-14 w-14 rounded-sm bg-vellum/5 p-1"
      width={56}
      height={56}
      src={logo}
      alt={college}
    />
    <div class="md:hidden">
      <h3
        class="font-display text-2xl tracking-masthead text-vellum"
        style="font-variation-settings:'opsz' 144,'SOFT' 20,'wght' 440;"
      >
        {college}
      </h3>
    </div>
  </div>

  <div>
    <div class="hidden md:flex md:items-baseline md:justify-between md:gap-6">
      <h3
        class="font-display text-3xl tracking-masthead text-vellum"
        style="font-variation-settings:'opsz' 144,'SOFT' 20,'wght' 440;"
      >
        {college}
      </h3>
      <span class="font-mono text-[0.7rem] uppercase tracking-widest text-bone">
        {startDate} – {endDate}
      </span>
    </div>
    <p class="mt-1 font-mono text-[0.72rem] uppercase tracking-widest text-bone md:hidden">
      {startDate} – {endDate}
    </p>
    <div class="mt-4 text-bone">
      <slot />
    </div>
  </div>
</article>
