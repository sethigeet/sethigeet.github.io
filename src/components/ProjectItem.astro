---
import { Image } from "astro:assets";

import githubIcon from "@assets/icons/github.svg";
import type { Technology } from "@lib/logos";
import TechLogo from "./TechLogo.astro";

interface Props {
  name: string;
  skills: Technology[];
  coverImage: ImageMetadata;
  sourceCodeUrl?: string;
  index: string;
}
const { name, skills, coverImage, sourceCodeUrl, index } = Astro.props;
---

<article
  class="project-row group relative grid grid-cols-1 gap-10 border-t border-rule py-14 md:grid-cols-12 md:gap-10"
>
  <!-- Index number + meta -->
  <div class="md:col-span-1">
    <p
      class="font-display text-5xl leading-none tracking-masthead text-ember md:text-6xl"
      style="font-variation-settings:'opsz' 144,'SOFT' 20,'wght' 380;"
    >
      {index}
    </p>
  </div>

  <!-- Content -->
  <div class="project-content md:order-2 md:col-span-6">
    <div class="flex flex-wrap items-center gap-3">
      <h2
        class="font-display text-4xl leading-[1.02] tracking-masthead text-vellum md:text-5xl"
        style="font-variation-settings:'opsz' 144,'SOFT' 25,'wght' 440;"
      >
        {name}
      </h2>
      {
        sourceCodeUrl && (
          <a
            href={sourceCodeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 border border-ember/60 px-2 py-0.5 font-mono text-[0.62rem] uppercase tracking-widest text-ember transition-colors hover:bg-ember hover:text-ink"
          >
            <Image src={githubIcon} alt="" class="h-3 w-3 opacity-90 invert" />
            Open source
          </a>
        )
      }
    </div>

    <div class="mt-5 text-base leading-relaxed text-bone">
      <slot />
    </div>

    <div class="mt-7">
      <p class="font-mono text-[0.62rem] uppercase tracking-widest text-ash">
        Technologies
      </p>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        {skills.map((skill) => <TechLogo name={skill} size={26} />)}
      </div>
    </div>
  </div>

  <!-- Image -->
  <div class="project-image md:order-1 md:col-span-5">
    <Image
      class="h-auto w-full transition-transform duration-[1200ms] ease-out group-hover:scale-[1.015]"
      style="filter: drop-shadow(0 0 3rem rgb(75 202 234 / 0.28)) drop-shadow(0 0 1rem rgb(75 202 234 / 0.18));"
      src={coverImage}
      alt={`${name} showcase`}
    />
  </div>
</article>
