---
import { Image } from "astro:assets";

import githubIcon from "@assets/icons/github.svg";
import type { Technology } from "@lib/logos";
import TechLogo from "./TechLogo.astro";

interface Props {
  name: string;
  skills: Technology[];
  index: string;
  artifactLabel?: string;
  sourceCodeUrl?: string;
}

const { name, skills, index, artifactLabel, sourceCodeUrl } = Astro.props;
---

<article
  class="project-row group relative grid grid-cols-1 gap-10 border-t border-rule py-14 md:grid-cols-12 md:gap-10"
>
  <div class="md:col-span-1">
    <p
      class="font-display text-5xl leading-none tracking-masthead text-ember md:text-6xl"
      style="font-variation-settings:'opsz' 144,'SOFT' 20,'wght' 380;"
    >
      {index}
    </p>
  </div>

  <div class="project-content md:order-2 md:col-span-6">
    <div class="flex flex-wrap items-center gap-3">
      <h2
        class="font-display text-4xl leading-[1.02] tracking-masthead text-vellum md:text-5xl"
        style="font-variation-settings:'opsz' 144,'SOFT' 25,'wght' 440;"
      >
        {name}
      </h2>
      {
        sourceCodeUrl && (
          <a
            href={sourceCodeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 border border-ember/60 px-2 py-0.5 font-mono text-[0.62rem] uppercase tracking-widest text-ember transition-colors hover:bg-ember hover:text-ink"
          >
            <Image src={githubIcon} alt="" class="h-3 w-3 opacity-90 invert" />
            Open source
          </a>
        )
      }
    </div>

    <div class="mt-5 text-base leading-relaxed text-bone">
      <slot />
    </div>

    <div class="mt-7">
      <p class="font-mono text-[0.62rem] uppercase tracking-widest text-ash">
        Technologies
      </p>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        {skills.map((skill) => <TechLogo name={skill} size={26} />)}
      </div>
    </div>
  </div>

  <div class="project-image md:order-1 md:col-span-5">
    <div
      class="relative min-h-[18rem] overflow-hidden border border-rule bg-[radial-gradient(circle_at_top_left,rgba(75,202,234,0.18),transparent_34%),linear-gradient(135deg,rgba(255,255,255,0.02),rgba(255,255,255,0.01))] p-8"
    >
      <div class="absolute inset-0 opacity-40" aria-hidden="true">
        <div
          class="absolute -right-12 top-10 h-32 w-32 rounded-full border border-ember/25"
        >
        </div>
        <div
          class="absolute bottom-6 left-6 h-24 w-24 rounded-full border border-vellum/10"
        >
        </div>
        <div
          class="absolute inset-x-0 top-1/2 border-t border-dashed border-rule/60"
        >
        </div>
      </div>

      <div class="relative flex h-full flex-col justify-between">
        <p
          class="font-mono text-[0.62rem] uppercase tracking-[0.32em] text-ember/90"
        >
          {artifactLabel ?? "Resume project"}
        </p>

        <div>
          <p
            class="font-mono text-[0.68rem] uppercase tracking-widest text-ash"
          >
            Project {index}
          </p>
          <h3
            class="mt-3 max-w-sm font-display text-4xl leading-[1.02] tracking-masthead text-vellum md:text-5xl"
            style="font-variation-settings:'opsz' 144,'SOFT' 24,'wght' 430;"
          >
            {name}
          </h3>
        </div>
      </div>
    </div>
  </div>
</article>
